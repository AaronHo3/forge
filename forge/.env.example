# Forge configuration — copy this file to `.env` and fill in your values.
# The server auto-loads forge/.env on startup, so you never type these on the
# command line. Real environment variables take precedence over this file.

# Audiotool Personal Access Token (get one at https://rpc.audiotool.com/dev).
# Required for the "↗ Audiotool" button to appear and work.
AUDIOTOOL_PAT=

# Which generation engine the workbench/games use: mrt2 (default) or sa3.
FORGE_BACKEND=sa3

# Anthropic key for the AI judge in the game modes (optional — falls back to a
# word-overlap heuristic if unset).
# ANTHROPIC_API_KEY=

# Stable Audio 3 checkout location (only if it differs from the spike default).
# FORGE_SA3_DIR=/Users/aaronho/Desktop/MusicHack/sa3-spike/stable-audio-3
